
# 🌍 Основные настройки
mixed-port: 7890
allow-lan: true
ipv6: false
mode: global
log-level: info
external-controller: 127.0.0.1:9090

# 🌐 DNS (ускоренный, универсальный fake-ip)
dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  default-nameserver:
    - 8.8.8.8
    - 1.1.1.1
  nameserver:
    - https://dns.google/dns-query
    - https://1.1.1.1/dns-query
    - https://77.88.8.8/dns-query # Яндекс DNS
    - https://9.9.9.9/dns-query   # Quad9
  fallback-filter:
    geoip: true

# 🌀 TUN (для полного захвата трафика)
tun:
  enable: true
  stack: gvisor
  auto-route: true
  auto-detect-interface: true


